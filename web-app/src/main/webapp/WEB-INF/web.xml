<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>CORBA PDF Service</display-name>
    <description>Application Web de gestion PDF via CORBA</description>

    <!-- Servlet de bienvenue -->
    <welcome-file-list>
        <welcome-file>index.jsp</welcome-file>
    </welcome-file-list>

    <!-- Paramètres de contexte pour CORBA -->
    <context-param>
        <param-name>corba.host</param-name>
        <param-value>localhost</param-value>
    </context-param>
    <context-param>
        <param-name>corba.port</param-name>
        <param-value>1050</param-value>
    </context-param>

    <!-- Encodage UTF-8 -->
    <filter>
        <filter-name>CharacterEncodingFilter</filter-name>
        <filter-class>org.apache.catalina.filters.SetCharacterEncodingFilter</filter-class>
        <init-param>
            <param-name>encoding</param-name>
            <param-value>UTF-8</param-value>
        </init-param>
    </filter>
    <filter-mapping>
        <filter-name>CharacterEncodingFilter</filter-name>
        <url-pattern>/*</url-pattern>
    </filter-mapping>

    <!-- Taille max upload: 50MB -->
    <context-param>
        <param-name>maxFileSize</param-name>
        <param-value>52428800</param-value>
    </context-param>

</web-app>
